# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# Airbtics API key — used server-side by /api/estimate to fetch real
# market data from Airbtics. Get yours from the Airbtics dashboard.
# When unset, /api/estimate falls back to mock data so the UI still works.
AIRBTICS_API_KEY=

# Public app URL (used by Nav for the Sign In / Register links).
# Default is the dev domain — override per environment.
NEXT_PUBLIC_APP_URL=https://dev.rentroyz.com
